# ── Telegram credentials (my.telegram.org → API development tools) ───────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+998901234567        # твой номер в международном формате

# ── Где работает бот ──────────────────────────────────────────────────────────
# Отвечать ли в личке (true/false). По умолчанию только группы.
ALLOW_PRIVATE_CHATS=false
# ID пользователей, которым бот никогда не отвечает (через запятую)
IGNORED_USER_IDS=

# ── Поведение ─────────────────────────────────────────────────────────────────
# true = тихий режим: бот видит сообщения и логирует, но ничего не отправляет
DRY_RUN=true
# Максимум одновременных диалогов
MAX_CONCURRENT_CHATS=25
# Задержка перед ответом (секунды, дробные допустимы)
REPLY_DELAY_MIN=2.0
REPLY_DELAY_MAX=5.0

# ── Уведомления ───────────────────────────────────────────────────────────────
# ID группы, куда дублируются все ответы бота (0 = отключено)
NOTIFICATION_CHAT_ID=0
# ID группы для CRM-сводок менеджеру
MANAGER_GROUP_ID=

# ── RAG: источники знаний ────────────────────────────────────────────────────
# Юзернеймы/ID каналов и групп через запятую
MONITORED_CHANNELS=

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google Drive ──────────────────────────────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=./config/service_account.json

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Формат: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bot_analytics

# ── Администраторы ────────────────────────────────────────────────────────────
# Твой Telegram ID (узнать: написать @userinfobot)
ADMIN_USER_IDS=
